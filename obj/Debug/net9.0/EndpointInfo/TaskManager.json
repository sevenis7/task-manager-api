        ],
        "summary": "Получить данные по ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Priority/{id}": {
      "get": {
        "tags": [
          "Priority"
        ],
        "summary": "Получить данные по ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Status/{id}": {
      "get": {
        "tags": [
          "Status"
        ],
        "summary": "Получить данные по ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Task": {
      "get": {
        "tags": [
          "Task"
        ],
        "summary": "Метод получения задач",
        "parameters": [
          {
            "name": "includeExpired",
            "in": "query",
            "description": "Параметр, включающий истекшие задачи по сроку истечения. По умолчанию false.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "onlyExpired",
            "in": "query",
            "description": "Параметр, включающий ТОЛЬКО истекшие задачи по сроку истечения. По умолчанию false",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "categoryId",
            "in": "query",
            "description": "ID параметр выбранной категории. Без указания будут получены задачи всех категорий.",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "statusId",
            "in": "query",
            "description": "ID параметр выбранного статуса. Без указания будут получени задачи со всеми статусами",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Task"
        ],
        "summary": "Метод создания задачи",
        "requestBody": {
          "description": "Модель задачи CreateTaskModel, принимаемая из тела запроса",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTaskModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTaskModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTaskModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Task/{id}": {
      "get": {
        "tags": [
          "Task"
        ],
        "summary": "Метод получения задачи",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID задачи",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "patch": {
        "tags": [
          "Task"
        ],
        "summary": "Метод изменения задачи",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID изменяемой задачи",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "description": "Модель задачи UpdateTaskModel, принимаемая из тела запроса",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTaskModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTaskModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTaskModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "delete": {
        "tags": [
          "Task"
        ],
        "summary": "Метод удаления задачи",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID удаляемой задачи",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Task/{id}/change-status": {
      "patch": {
        "tags": [
          "Task"
        ],
        "summary": "Метод изменения статуса задачи",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID задачи в которой меняется статус",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "description": "ID статуса присваиваемый задаче",
          "content": {
            "application/json": {
              "schema": {
                "type": "integer",
                "format": "int32"
              }
            },
            "text/json": {
              "schema": {
                "type": "integer",
                "format": "int32"
              }
            },
            "application/*+json": {
              "schema": {
                "type": "integer",
                "format": "int32"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateTaskModel": {
        "required": [
          "description",
          "name",
          "priorityId"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "description": {
            "minLength": 1,
            "type": "string"
          },
          "dueDate": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "categoryId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "priorityId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "UpdateTaskModel": {
        "required": [
          "description",
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "description": {
            "minLength": 1,
            "type": "string"
          },
          "dueDate": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "categoryId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "priroityId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
